{
  "name": "goclick",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --experimental-https --hostname goclick",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "node -e \"process.env.TS_NODE_COMPILER_OPTIONS=JSON.stringify({module:'CommonJS'});require('child_process').execSync('npx ts-node prisma/seed.ts',{stdio:'inherit',env:process.env})\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "iron-session": "^8.0.1",
    "next": "14.0.4",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "prisma": "^5.7.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
